---
// import pathe from 'pathe';
import '../styles/common.scss';
import '../styles/base/core/_utils.scss';
import AstroFont from '@plugins/astro-font/AstroFont.astro';
import { localizedHTML as favicons } from 'astro-favicons/middleware';
import Header from '../sections/Header.astro';
import PlanBanner from '../sections/PlanBanner.astro';
import Footer from '../sections/Footer.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;

const currentPageUrl = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, viewport-fit=cover"
    />
    <meta http-equiv="X-UA-Compatible" content="ie=edge" />
    <Fragment set:html={favicons(Astro.currentLocale)} />
    <meta name="generator" content={Astro.generator} />
    {description && <meta name="description" content={description} />}
    <title>{title}</title>
    <AstroFont
      config={[
        {
          name: 'Manrope',
          preload: false,
          fallback: 'sans-serif',
          fallbackName: 'Manrope-fallback',
          googleFontsURL:
            'https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&display=swap',
          subsets: ['latin'],
        },
        /* {
          name: 'Inter',
          preload: false,
          fallback: 'sans-serif',
          fallbackName: 'Inter-fallback',
          googleFontsURL:
          'https://fonts.bunny.net/css?family=inter:400,500,600&display=swap',
          subsets: ['latin'],
        }, */
        /* {
          name: 'Eudoxus Sans',
          preload: false,
          fallback: 'sans-serif',
          src: [
            {
              style: 'normal',
              weight: '500',
              path: pathe.join(process.cwd(), 'src', 'fonts', 'EudoxusSans-Medium-subset.woff2')
            }
          ],
        } */
      ]}
    />
    <!-- Fonts containing only a few letters (Logo text): -->
    <!-- 1. Get font link like `https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300..700&display=swap&text=Logo` -->
    <!-- 2. Get inline code: https://amio.github.io/embedded-google-fonts/ -->
    <!--    <style>
      @font-face {
        font-family: 'Space Grotesk';
        font-style: normal;
        font-weight: 500;
        font-display: swap;
        src: url(data:font/woff2;base64,) format('woff2');
      }
    </style>-->
    <script>
      window.addEventListener('load', function () {
        document.body.classList.add('loaded');
      });
    </script>
    <script src="../js/base.ts"></script>
  </head>
  <body>
    <Header currentPageUrl={currentPageUrl} />

    <main class="main">
      <slot />
      <PlanBanner />
    </main>

    <Footer />
  </body>
</html>

<style is:global>
  .main {
    margin-bottom: var(--section-padding-v);
  }

  #group-mq {
    top: 0;
  }
</style>
