---
import { SvgIcon } from '@/core';

interface Props {
  class?: string;
  href?: string;
  icon?: string;
  stretch?: boolean;
  dark?: boolean;
}

const {
  class: className,
  href,
  icon,
  stretch = false,
  dark = false,
} = Astro.props;

const Tag = href !== undefined ? 'a' : 'button';

const attrs = {} as Record<string, string>;

if (href) {
  attrs.href = href;
} else {
  attrs.type = 'button';
}
---

<Tag
  class:list={[
    'btn',
    stretch && 'btn--stretch',
    dark && 'btn--dark',
    className,
  ]}
  {...attrs}
>
  {icon && <SvgIcon name={icon} class="btn__icon" />}
  <slot />
</Tag>

<style lang="scss" is:global>
  @use '@styles/base' as *;

  .btn {
    @include reset-btn;

    @include inline-flex-center;
    @include padding-fluid(18px 24px, 14px 24px $laptop);
    @include column-gap(4px);

    @include font-size-fluid(18px, 14px $laptop);
    font-weight: 600;
    color: var(--absolute-white);

    background-color: var(--red-45);
    border-radius: 8px;

    white-space: nowrap;

    @include hover {
      background-color: var(--red-55);
    }

    &--stretch {
      width: 100%;
    }

    &--dark {
      background-color: var(--black-08);
      border: 1px solid var(--black-15);

      @include hover {
        background-color: var(--black-15);
      }
    }

    &__icon {
      @include box(28px, 24px $laptop);
    }
  }
</style>
