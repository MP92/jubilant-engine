---
import HTag from './HTag.astro';
import RatingBadge from './RatingBadge.astro';

interface Props {
  class?: string;
  hLvl: number;
  author: string;
  country: string;
  grade: number;
  text: string;
}

const {
  class: className,
  hLvl,
  author,
  country,
  grade,
  text,
  ...rest
} = Astro.props;
---

<article class:list={['review-card', className]} {...rest}>
  <header class="review-card__header">
    <HTag class="review-card__title h-20-18-16" lvl={hLvl}>{author}</HTag>
    <span class="review-card__country">From {country}</span>
    <RatingBadge class="review-card__rating" grade={grade} />
  </header>

  <div class="review-card__text">
    <p>{text}</p>
  </div>
</article>

<style lang="scss" is:global>
  @use '@styles/base' as *;

  .review-card {
    @include flex-column;
    @include row-gap(20px, 16px $laptop);
    @include padding(40px, 30px $laptop, 24px $tablet-s);

    background: var(--black-06);
    border: 1px solid var(--black-15);
    border-radius: 12px;

    &__header {
      display: grid;
      grid-template-columns: 1fr auto;
      @include column-gap(10px);
      align-items: center;
    }

    &__title {
      grid-column: 1 / span 1;
    }

    &__country {
      grid-row: 2 / span 1;

      font-weight: 500;
    }

    &__rating {
      grid-row: 1 / span 2;
      grid-column: 2 / span 1;

      .rating {
        @include column-gap(4px, 2px $laptop);

        @include font-size(18px, 14px $laptop);
        font-weight: 500;
      }
    }

    &__text {
    }
  }
</style>
