---
import Accordion from './Accordion.astro';

interface Props {
  class?: string;
  columns?: number;
  name: string;
  items: {
    title: string;
    description: string;
  }[];
}

const { class: className, columns = 1, name, items, ...rest } = Astro.props;

const detailsId = (index: number) => `${name}-${index}`;

const isBottomItem = (index: number) => {
  return columns > 1 && (index + 1) % Math.ceil(items.length / columns) === 0;
};
---

<div class:list={['accordion-group', className]} {...rest}>
  <ol
    class:list={[
      'accordion-group__list',
      columns > 1 && `accordion-group__list--${columns}-cols`,
    ]}
  >
    {
      items.map((item, index) => (
        <li
          class:list={[
            'accordion-group__item',
            isBottomItem(index) && 'accordion-group__item--bottom',
          ]}
        >
          <Accordion
            name={name}
            id={detailsId(index)}
            title={item.title}
            description={item.description}
            isOpen={index === 0}
          />
        </li>
      ))
    }
  </ol>
</div>

<style lang="scss" is:global>
  @use '@styles/base' as *;

  .accordion-group {
    &__list {
      list-style: none;
      counter-reset: accordion-counter;

      &--2-cols {
        @include column-gap(80px, 40px $laptop, 20px $tablet);

        @include higher-tablet {
          column-count: 2;
        }
      }
    }

    &__item {
      counter-increment: accordion-counter;

      break-inside: avoid;

      position: relative;

      &::after {
        content: '';

        position: absolute;
        inset: 0;
        top: unset;

        height: 1px;

        background-image: linear-gradient(
          90deg,
          rgb(229 0 0 / 0%) 0%,
          var(--red-45) 16.67%,
          rgb(229 0 0 / 0%) 100%
        );
      }

      &:last-child::after {
        content: none;
      }

      &--bottom::after {
        @include higher-tablet {
          content: none;
        }
      }
    }
  }
</style>
