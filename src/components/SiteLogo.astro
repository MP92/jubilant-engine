---
import { MyImage } from '@/core';
import { withBase } from '../js/utils/urls';

interface Props {
  class: string;
}

const { class: className } = Astro.props;
---

<a
  class:list={['site-logo', className]}
  href={withBase('/')}
  title="Home"
  aria-label="Home"
>
  <MyImage src="@img/icons/site-logo.svg" alt="" loading="eager" />
</a>
