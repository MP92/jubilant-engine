---
interface Props {
  class?: string;
  title: string;
  description: string;
  authorName: string;
  url?: string;
}

const { class: className, title, description, authorName, url } = Astro.props;
---

<div class:list={['card', className]}>
  <h2 class="card-title">
    {title}
  </h2>

  <p class="card-description">
    {description}
  </p>

  <div class="card-author">
    {authorName}
  </div>

  <a href={url} class="card-button"> Читать статью → </a>
</div>

<style lang="scss">
  @use '@styles/base' as *;

  .card {
    @include flex-column;

    max-width: 380px;
    width: 100%;
    background: white;
    border-radius: 24px;
    padding: 28px;
    box-shadow: 0 20px 40px -12px rgb(0 0 0 / 10%);
    font-family: Inter, sans-serif;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
    border: 1px solid rgb(0 0 0 / 5%);
  }

  .card:hover {
    transform: translateY(-4px);
    box-shadow: 0 30px 50px -12px rgb(0 0 0 / 15%);
  }

  .card-title {
    font-size: 24px;
    font-weight: 700;
    color: #1a1a2c;
    margin-bottom: 12px;
    line-height: 1.3;
    letter-spacing: -0.02em;
  }

  .card-description {
    font-size: 15px;
    line-height: 1.5;
    color: #4a4a68;
    margin-bottom: 20px;
    font-weight: 400;
  }

  .card-author {
    margin-top: auto;

    font-size: 14px;
    color: #667eea;
    font-weight: 500;
    margin-bottom: 24px;
    padding-bottom: 20px;
    border-bottom: 1px solid rgb(0 0 0 / 5%);
  }

  .card-button {
    background: #667eea;
    color: white;
    border: none;
    padding: 12px 24px;
    border-radius: 40px;
    font-size: 15px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
    width: 100%;
    text-decoration: none;
    display: inline-block;
    text-align: center;
  }

  .card-button:hover {
    background: #5a67d8;
    transform: scale(1.02);
  }

  @media (max-width: 480px) {
    .card {
      padding: 24px;
    }

    .card-title {
      font-size: 22px;
    }
  }

  @media (prefers-color-scheme: dark) {
    .card {
      background: #1e1e2e;
      border-color: rgb(255 255 255 / 5%);
    }

    .card-title {
      color: #fff;
    }

    .card-description {
      color: #b8b8d0;
    }

    .card-author {
      color: #9f7aea;
      border-bottom-color: rgb(255 255 255 / 5%);
    }
  }
</style>
