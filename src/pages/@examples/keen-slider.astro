---
import ExampleLayout from '@/@examples/ExampleLayout.astro';
import ExampleKeenSlider from '@/@examples/components/ExampleKeenSlider.astro';
import ExampleCard from '@/@examples/components/ExampleCard.astro';
import '@/@examples/example.scss';
import sliderData from '@/@examples/data/slider.json';
---

<script>
  import KeenSliderCollection from '@/js/modules/keenSlider';
  new KeenSliderCollection();
</script>

<ExampleLayout title="Examples | Keen Slider">
  <div class="example">
    <div class="container">
      <h1 class="example__title">Keen Slider</h1>

      <ExampleKeenSlider itemComponent={ExampleCard} items={sliderData} />
    </div>
  </div>
</ExampleLayout>
