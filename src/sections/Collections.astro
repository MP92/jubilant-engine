---

<Tabs
  class="collections container"
  title={collectionsTitle}
  itemComponent={Collection}
  items={collectionsTabsData}
  onlySm={true}
/>

<style lang="scss" is:global>
  @use '@styles/base' as *;

  .collections {
    @include var(--tabs-panels-gap, 150px, 120px $laptop, 0 $tablet-s);
  }
</style>
