{
  "name": "astro-template-html",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "eslint": "npx eslint --cache --cache-location ./node_modules/.cache/eslint/.eslintcache ./",
    "eslint:fix": "npx eslint --fix --cache --cache-location ./node_modules/.cache/eslint/.eslintcache ./",
    "stylelint": "npx stylelint src/**/*.{css,scss,vue,astro} --cache --cache-location ./node_modules/.cache/stylelint/.stylelintcache",
    "stylelint:fix": "npx stylelint src/**/*.{css,scss,vue,astro} --cache --cache-location ./node_modules/.cache/stylelint/.stylelintcache --fix",
    "prettier": "npx prettier . --check --cache",
    "prettier:fix": "npx prettier . --check --write --cache",
    "postinstall": "patch-package"
  },
  "browserslist": [
    ">= .25% and not dead"
  ],
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/ts-plugin": "^1.10.5",
    "astro": "^5.16.4",
    "astro-compressor": "^1.2.0",
    "astro-favicons": "^3.1.5",
    "keen-slider": "^6.8.6",
    "source-map": "^0.7.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@minko-fe/postcss-pxtorem": "^1.5.0",
    "@types/clean-css": "^4.2.11",
    "@types/fontkit": "^2.0.8",
    "@types/jscodeshift": "^17.3.0",
    "@typescript-eslint/parser": "^8.46.1",
    "astro-icon": "^1.1.5",
    "clean-css": "^5.3.3",
    "console-table-printer": "^2.14.6",
    "crittr": "github:MP92/crittr",
    "cssnano": "^7.1.1",
    "eslint": "^9.37.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.3.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "fontkit": "^2.0.4",
    "glob": "^13.0.0",
    "globals": "^16.4.0",
    "inline-critical": "^12.1.0",
    "jscodeshift": "^17.3.0",
    "mrmime": "^2.0.1",
    "normalize-newline": "^5.0.0",
    "patch-package": "^8.0.1",
    "pathe": "^2.0.3",
    "postcss": "^8.5.6",
    "postcss-discard": "^2.0.0",
    "postcss-html": "^1.8.0",
    "postcss-lightningcss": "^1.0.2",
    "postcss-load-config": "^6.0.1",
    "postcss-rename": "^0.8.0",
    "postcss-sort-media-queries": "^5.2.0",
    "prettier": "^3.6.2",
    "prettier-plugin-astro": "^0.14.1",
    "puppeteer": "^24.25.0",
    "run-queue": "^2.0.1",
    "sass-embedded": "^1.93.2",
    "sharp": "^0.34.4",
    "slash": "^5.1.0",
    "stylelint": "^16.25.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-standard-scss": "^16.0.0",
    "typescript-eslint": "^8.46.1",
    "vite-plugin-image-optimizer": "^2.0.2"
  }
}
